# ====== Required ======

# Claude model for article generation (sonnet, opus, haiku)
CLAUDE_MODEL=sonnet

# PPIO API key — used for QC cross-validation (MiniMax M2.5)
# Get from: https://ppio.ai
PPIO_API_KEY=

# Tavily API key — used for web search in pre-search phase
# Get from: https://tavily.com
TAVILY_API_KEY=

# ====== Optional ======

# Access password (protect web UI when exposed publicly)
# ACCESS_PASSWORD=

# Claude timeout per job (seconds, default: 480)
# CLAUDE_TIMEOUT=480

# Feishu SEO Stats (飞书多维表格)
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_BITABLE_APP_TOKEN=
# FEISHU_TABLE_HISTORY=
# FEISHU_TABLE_ARTICLES=
